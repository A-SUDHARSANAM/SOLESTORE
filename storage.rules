rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
        && (
          request.auth.token.admin == true
          || request.auth.uid in get(/databases/$(database)/documents/storeSettings/primary).data.adminUids
        );
    }

    match /products/{productId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read: if false;
      allow write: if isAdmin();
    }
  }
}
